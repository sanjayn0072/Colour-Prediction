            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Player\",\n  \"phone\": \"+919999999999\",\n  \"email\": \"testplayer@colourplay.com\",\n  \"password\": \"Player@1234\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/send-otp",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
